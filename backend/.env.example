# ==========================================
# SmartStock IA - Configuración de Entorno
# ==========================================

# Base de Datos
# Para SQLite (desarrollo local): sqlite:///./smartstock.db
# Para MySQL: mysql+pymysql://usuario:contraseña@localhost/smartstock
# Para PostgreSQL: postgresql://usuario:contraseña@localhost/smartstock
DATABASE_URL=sqlite:///./smartstock.db

# Google Generative AI (Gemini) - OPCIONAL
# Si no se proporciona una API Key, el sistema usa fallbacks realistas
# Obtén tu API Key en: https://ai.google.dev/
# GEMINI_API_KEY=tu_api_key_aqui_sin_comillas

# Configuración de Servidor
# API_HOST=127.0.0.1
# API_PORT=8000
# API_RELOAD=true
